# Base URL of the legacy ASP.NET Core API (used only by the API-backed admin
# modules, which are hidden in the demo). Safe to leave as-is for the demo.
NEXT_PUBLIC_API_URL=http://localhost:5122

# Supabase — backs the demo inquiry workflow. Find these in your Supabase
# project: Settings -> API. The anon/publishable key is safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
